{
  "type": "module",
  "name": "ink-lingo-backend",
  "version": "1.0.0",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "main": "app.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "npm run build:ts && tsc -p test/tsconfig.json && cross-env FASTIFY_AUTOLOAD_TYPESCRIPT=1 node --import ./test/register-loader.mjs --test --experimental-test-coverage test/**/*.ts",
    "start": "npm run build:ts && fastify start -l info dist/app.js",
    "build:ts": "tsc",
    "watch:ts": "tsc -w",
    "dev": "fastify start -l info src/app.ts",
    "dev:start": "fastify start --ignore-watch=.ts$ -w -l info -P dist/app.js",
    "migrate:up": "node-pg-migrate -d NEON_DATABASE_URL --envPath .env up",
    "migrate:down": "node-pg-migrate -d NEON_DATABASE_URL --envPath .env down",
    "migrate:create": "node-pg-migrate -j ts create"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.1090.0",
    "@fastify/autoload": "^6.0.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/sensible": "^6.0.0",
    "@neondatabase/serverless": "^1.1.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "fastify-cli": "^8.0.0",
    "fastify-plugin": "^5.0.0",
    "node-pg-migrate": "^9.0.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/pg": "^8.20.0",
    "c8": "^11.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "fastify-tsconfig": "^3.0.0",
    "ts-node": "^10.4.0",
    "typescript": "~5.9.2"
  }
}
