{
  "name": "infra",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "diff:auth": "cdk diff AuthStack -c stack=AuthStack",
    "diff:api": "cdk diff ApiStack -c stack=ApiStack",
    "deploy:auth": "cdk deploy AuthStack -c stack=AuthStack",
    "deploy:api": "cdk deploy ApiStack -c stack=ApiStack",
    "deploy:all": "cdk deploy --all"
  },
  "devDependencies": {
    "@swc/core": "^1.15.0",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1132.0",
    "jest": "^30",
    "tsx": "^4.23.0",
    "typescript": "~7.0.2"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.261.0",
    "constructs": "^10.5.0"
  }
}
