{
  "name": "infra",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "diff:frontend": "cdk diff InkLingo-FrontendStack -c stack=FrontendStack",
    "diff:auth": "cdk diff InkLingo-AuthStack -c stack=AuthStack",
    "diff:api": "cdk diff InkLingo-ApiStack -c stack=ApiStack",
    "diff:github-oidc": "cdk diff InkLingo-GithubOidcStack -c stack=GithubOidcStack",
    "deploy:frontend": "cdk deploy InkLingo-FrontendStack -c stack=FrontendStack",
    "deploy:auth": "cdk deploy InkLingo-AuthStack -c stack=AuthStack",
    "deploy:api": "cdk deploy InkLingo-ApiStack -c stack=ApiStack",
    "deploy:github-oidc": "cdk deploy InkLingo-GithubOidcStack -c stack=GithubOidcStack",
    "deploy:all": "cdk deploy --all",
    "destroy:frontend": "cdk destroy InkLingo-FrontendStack -c stack=FrontendStack",
    "destroy:auth": "cdk destroy InkLingo-AuthStack -c stack=AuthStack",
    "destroy:api": "cdk destroy InkLingo-ApiStack -c stack=ApiStack",
    "destroy:github-oidc": "cdk destroy InkLingo-GithubOidcStack -c stack=GithubOidcStack",
    "destroy:app": "cdk destroy InkLingo-ApiStack InkLingo-AuthStack InkLingo-FrontendStack",
    "destroy:all": "cdk destroy --all",
    "write-frontend-env": "node scripts/write-frontend-env.mjs"
  },
  "devDependencies": {
    "@swc/core": "^1.15.0",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1132.0",
    "jest": "^30",
    "tsx": "^4.23.0",
    "typescript": "~7.0.2"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.261.0",
    "constructs": "^10.5.0"
  }
}
